{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/telegram-notifications/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/telegram-notifications/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps",
  "projects": {
    "consumer": {
      "type": "application",
      "root": "apps/consumer",
      "entryFile": "main",
      "sourceRoot": "apps/consumer/src",
      "compilerOptions": {
        "deleteOutDir": true,
        "webpack": true,
        "tsConfigPath": "apps/consumer/tsconfig.app.json"
      }
    },
    "producer": {
      "type": "application",
      "root": "apps/producer",
      "entryFile": "main",
      "sourceRoot": "apps/producer/src",
      "compilerOptions": {
        "deleteOutDir": true,
        "webpack": true,
        "tsConfigPath": "apps/producer/tsconfig.app.json"
      }
    },
    "telegram-notifications": {
      "type": "application",
      "root": "apps/telegram-notifications",
      "entryFile": "main",
      "sourceRoot": "apps/telegram-notifications/src",
      "compilerOptions": {
        "deleteOutDir": true,
        "webpack": true,
        "tsConfigPath": "apps/telegram-notifications/tsconfig.app.json"
      }
    }
  }
}